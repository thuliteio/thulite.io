{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{ with .Site.Home }}
    {{- if and (ne .Sitemap.Disable true) (ne .Params.sitemap false) -}}
      {{- with .OutputFormats.Get "sitemap" -}}
  <sitemap>
    <loc>{{ .Permalink }}</loc>{{ if not $.Site.Home.Lastmod.IsZero }}
    <lastmod>{{ safeHTML ( $.Site.Home.Lastmod.Format "2006-01-02T15:04:05-07:00" ) }}</lastmod>{{ end }}
  </sitemap>
      {{- end -}}
    {{- end -}}
  {{ end }}

  {{ range where .Site.Pages "Kind" "section" }}
    {{- if and (ne .Sitemap.Disable true) (ne .Params.sitemap false) -}}
      {{- $section := . -}}
      {{- with .OutputFormats.Get "sitemap" -}}
  <sitemap>
    <loc>{{ .Permalink }}</loc>{{ if not $section.Lastmod.IsZero }}
    <lastmod>{{ safeHTML ( $section.Lastmod.Format "2006-01-02T15:04:05-07:00" ) }}</lastmod>{{ end }}
  </sitemap>
      {{- end -}}
    {{- end -}}
  {{ end }}
</sitemapindex>
